# Choose one provider: gemini or openai.
AI_PROVIDER=gemini

# Gemini configuration. Server-only secret; never prefix it with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3-flash-preview

# OpenAI-compatible configuration. Works with OpenAI and compatible /chat/completions APIs.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
# Set false if a compatible provider does not support response_format=json_object.
OPENAI_JSON_MODE=true

# Optional cost-control settings for the public AI endpoint.
AI_SCORE_ENABLED=true
AI_SCORE_REQUESTS_PER_MINUTE=8
AI_SCORE_CACHE_TTL_SECONDS=43200
