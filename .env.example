# Server-only secret. Never prefix this variable with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Optional: defaults to the official Gemini API endpoint.
# Set this only when using a Google-compatible proxy that accepts x-goog-api-key.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3-flash-preview

# Optional cost-control settings for the public AI endpoint.
AI_SCORE_ENABLED=true
AI_SCORE_REQUESTS_PER_MINUTE=8
AI_SCORE_CACHE_TTL_SECONDS=43200
